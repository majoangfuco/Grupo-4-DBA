# Variables de entorno para el frontend - Copiar a .env.development o .env.production
# Vite automáticamente carga las variables con prefijo VITE_

# Backend API
VITE_API_BASE_URL=http://localhost:8081/api

# Ambiente
VITE_APP_ENV=development

# Feature flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true
