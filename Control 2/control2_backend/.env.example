# ================= BASE DE DATOS (POSTGRESQL) =================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=control2_bd
DB_USER=postgres
DB_PASSWORD=postgres
DB_DRIVER=org.postgresql.Driver

# ================= SERVIDOR =================
SERVER_PORT=8081
SERVER_SERVLET_ENCODING=UTF-8

# ================= HIBERNATE / JPA =================
JPA_HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true

# ================= SQL INITIALIZATION =================
SQL_INIT_MODE=always
SQL_INIT_CONTINUE_ON_ERROR=true

# ================= JWT (SEGURIDAD) =================
JWT_SECRET=EstaEsUnaClaveSecretaMuyLargaYSeguraParaElControl2DeArquitectura2026
JWT_EXPIRATION=86400000

# ================= EMAIL (NOTIFICACIONES) =================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_app_password
MAIL_FROM=noreply@sistematareas.com
MAIL_ENABLED=false

# ================= CORS =================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ================= LOGGING =================
LOG_LEVEL=INFO
